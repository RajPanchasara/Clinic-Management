@using FrontEnd_Exam_2.Models
@{
    Layout = "_Layout";
    ViewData["Title"] = "Users List";
    var users = ViewBag.Users as List<User> ?? new List<User>();
}

<main id="main" class="main">

    <div class="pagetitle">
        <h1>Users</h1>
        <nav>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Dashboard">Home</a></li>
                <li class="breadcrumb-item active">Users List</li>
            </ol>
        </nav>
    </div><!-- End Page Title -->

    @if (!string.IsNullOrEmpty(TempData["Success"] as string))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(ViewBag.Error as string))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-1"></i>
            @ViewBag.Error
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <section class="section">
        <div class="row">
            <div class="col-lg-12">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="card-title">Clinic Users</h5>
                            <a asp-controller="Admin" asp-action="CreateUser" class="btn btn-primary btn-sm">
                                <i class="bi bi-plus-circle me-1"></i> Add New User
                            </a>
                        </div>

                        @if (users.Count == 0)
                        {
                            <div class="alert alert-info">
                                <i class="bi bi-info-circle me-1"></i> No users found.
                            </div>
                        }
                        else
                        {
                            <table class="table table-hover datatable">
                                <thead>
                                    <tr>
                                        <th scope="col">#</th>
                                        <th scope="col">Name</th>
                                        <th scope="col">Email</th>
                                        <th scope="col">Role</th>
                                        <th scope="col">Phone</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ int rowNum = 1; }
                                    @foreach (var user in users)
                                    {
                                        var badgeClass = user.Role switch
                                        {
                                            "doctor" => "bg-primary",
                                            "receptionist" => "bg-warning text-dark",
                                            "patient" => "bg-success",
                                            "admin" => "bg-danger",
                                            _ => "bg-secondary"
                                        };

                                        <tr>
                                            <th scope="row">@rowNum</th>
                                            <td>@user.Name</td>
                                            <td>@user.Email</td>
                                            <td>
                                                <span class="badge @badgeClass">
                                                    @user.Role.ToUpper()
                                                </span>
                                            </td>
                                            <td>@(string.IsNullOrEmpty(user.Phone) ? "—" : user.Phone)</td>
                                        </tr>
                                        rowNum++;
                                    }
                                </tbody>
                            </table>
                        }

                    </div>
                </div>
            </div>
        </div>
    </section>

</main><!-- End #main -->
