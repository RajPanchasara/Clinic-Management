@{
    Layout = "_Layout";
    ViewData["Title"] = "Add Prescription";
    var appointmentId = ViewBag.AppointmentId;
}

<main id="main" class="main">

    <div class="pagetitle">
        <h1>Add Prescription</h1>
        <nav>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Doctor" asp-action="TodayQueue">Today's Queue</a></li>
                <li class="breadcrumb-item active">Add Prescription</li>
            </ol>
        </nav>
    </div>

    <section class="section">
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Prescription for Appointment #@appointmentId</h5>

                        @if (!string.IsNullOrEmpty(ViewBag.Error as string))
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <i class="bi bi-exclamation-triangle me-1"></i>
                                @ViewBag.Error
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }

                        <form id="prescriptionForm" asp-controller="Doctor" asp-action="AddPrescription"
                              asp-route-appointmentId="@appointmentId" method="post">

                            <input type="hidden" name="medicinesJson" id="medicinesJson" />

                            <!-- Medicines List -->
                            <div class="mb-3">
                                <label class="form-label fw-bold">Medicines <span class="text-danger">*</span></label>
                                <div id="medicinesList">
                                    <!-- Dynamic medicine rows will be added here -->
                                </div>
                                <button type="button" class="btn btn-outline-success btn-sm mt-2" id="addMedicineBtn">
                                    <i class="bi bi-plus-circle me-1"></i> Add Medicine
                                </button>
                            </div>

                            <!-- Notes -->
                            <div class="mb-3">
                                <label for="notes" class="form-label">Notes</label>
                                <textarea name="notes" class="form-control" id="notes" rows="3"
                                          placeholder="e.g. After food, Drink plenty of water"></textarea>
                            </div>

                            <!-- Submit -->
                            <div class="text-end">
                                <a asp-controller="Doctor" asp-action="TodayQueue" class="btn btn-secondary me-2">
                                    <i class="bi bi-arrow-left me-1"></i> Back
                                </a>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-circle me-1"></i> Save Prescription
                                </button>
                            </div>
                        </form>

                    </div>
                </div>
            </div>
        </div>
    </section>

</main>

@section Scripts {
    <script>
        var medicineIndex = 0;

        function addMedicineRow() {
            medicineIndex++;
            var html = `
                <div class="row g-2 mb-2 medicine-row" id="med-${medicineIndex}">
                    <div class="col-md-4">
                        <input type="text" class="form-control med-name" placeholder="Medicine name" required>
                    </div>
                    <div class="col-md-3">
                        <input type="text" class="form-control med-dosage" placeholder="Dosage (e.g. 500mg)" required>
                    </div>
                    <div class="col-md-3">
                        <input type="text" class="form-control med-duration" placeholder="Duration (e.g. 5 days)" required>
                    </div>
                    <div class="col-md-2">
                        <button type="button" class="btn btn-outline-danger btn-sm w-100" onclick="removeMedicine(${medicineIndex})">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </div>`;
            document.getElementById('medicinesList').insertAdjacentHTML('beforeend', html);
        }

        function removeMedicine(index) {
            var row = document.getElementById('med-' + index);
            if (row) row.remove();
        }

        // Add one row by default
        addMedicineRow();

        document.getElementById('addMedicineBtn').addEventListener('click', addMedicineRow);

        document.getElementById('prescriptionForm').addEventListener('submit', function (e) {
            var rows = document.querySelectorAll('.medicine-row');
            var medicines = [];

            rows.forEach(function (row) {
                var name = row.querySelector('.med-name').value.trim();
                var dosage = row.querySelector('.med-dosage').value.trim();
                var duration = row.querySelector('.med-duration').value.trim();

                if (name && dosage && duration) {
                    medicines.push({ name: name, dosage: dosage, duration: duration });
                }
            });

            if (medicines.length === 0) {
                e.preventDefault();
                alert('Please add at least one medicine.');
                return;
            }

            document.getElementById('medicinesJson').value = JSON.stringify(medicines);
        });
    </script>
}
