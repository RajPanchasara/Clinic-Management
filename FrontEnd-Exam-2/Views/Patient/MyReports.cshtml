@using FrontEnd_Exam_2.Models
@{
    Layout = "_Layout";
    ViewData["Title"] = "My Reports";
    var reports = ViewBag.Reports as List<Report> ?? new List<Report>();
}

<main id="main" class="main">

    <div class="pagetitle">
        <h1>My Reports</h1>
        <nav>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Patient" asp-action="MyAppointments">Home</a></li>
                <li class="breadcrumb-item active">My Reports</li>
            </ol>
        </nav>
    </div>

    @if (!string.IsNullOrEmpty(ViewBag.Error as string))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-1"></i>
            @ViewBag.Error
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <section class="section">
        <div class="row">
            <div class="col-lg-12">
                @if (reports.Count == 0)
                {
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-1"></i> No reports found.
                    </div>
                }
                else
                {
                    <table class="table table-hover datatable">
                        <thead>
                            <tr>
                                <th scope="col">#</th>
                                <th scope="col">Appointment</th>
                                <th scope="col">Diagnosis</th>
                                <th scope="col">Test Recommended</th>
                                <th scope="col">Remarks</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int rowNum = 1; }
                            @foreach (var report in reports)
                            {
                                <tr>
                                    <th scope="row">@rowNum</th>
                                    <td>#@report.AppointmentId</td>
                                    <td>@report.Diagnosis</td>
                                    <td>@(string.IsNullOrEmpty(report.TestRecommended) ? "—" : report.TestRecommended)</td>
                                    <td>@(string.IsNullOrEmpty(report.Remarks) ? "—" : report.Remarks)</td>
                                </tr>
                                rowNum++;
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </section>

</main>
